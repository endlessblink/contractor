{
  "name": "contractor",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node src/server.mjs",
    "generate": "node src/generate-quote.mjs",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "node build.mjs",
    "build:win": "node build.mjs --target win",
    "build:mac": "node build.mjs --target mac",
    "build:linux": "node build.mjs --target linux"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "description": "Self-hosted document generator for quotes, contracts and work orders. Hebrew RTL + English. Multi-provider AI (Anthropic, OpenAI, OpenRouter).",
  "dependencies": {
    "chrome-finder": "^1.0.7",
    "docx": "^9.6.0",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "open": "^10.1.0",
    "pdf-parse": "^2.4.5",
    "puppeteer": "^24.38.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.1",
    "esbuild": "^0.24.0"
  },
  "pkg": {
    "scripts": "dist/bundle.cjs",
    "assets": [
      "public/**/*",
      "assets/**/*",
      "knowledge/clauses-db.json",
      "data/user-profile.example.json"
    ],
    "targets": ["node20-linux-x64", "node20-macos-arm64", "node20-macos-x64", "node20-win-x64"],
    "outputPath": "dist/executables"
  }
}
